# Copy to .env and adjust.
# See docs/configuration.md for the full reference and ethics impact of each setting.

# =============================================================================
# App
# =============================================================================
DEBUG=true
LOG_LEVEL=INFO
APP_NAME=fs-spend

# =============================================================================
# Database (easy to swap via Alembic + SQLAlchemy)
# =============================================================================
DATABASE_URL=sqlite+aiosqlite:///./data/spend.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/spend

# Connection pooling (even for SQLite these are useful)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# =============================================================================
# Auth (Auth0 primary + Keycloak compatible)
# =============================================================================
# Excellent offline experience by default. Flip this for real IdP.
USE_LOCAL_TEST_KEYS=true

AUTH_ISSUER=https://your-tenant.auth0.com/
AUTH_AUDIENCE=https://api.fs-spend.example.com
# AUTH_JWKS_URL=https://your-tenant.auth0.com/.well-known/jwks.json

# Client credentials helper (used by /demo-token when client_id+secret provided)
# AUTH0_CLIENT_ID=...
# AUTH0_CLIENT_SECRET=...
# AUTH0_TOKEN_URL=https://your-tenant.auth0.com/oauth/token

# =============================================================================
# LLM / Agent (LiteLLM strings)
# =============================================================================
# Local Ollama is the default for the template (zero cost, deterministic, works offline)
LLM_MODEL=ollama/llama3.2

# Real hosted example (uncomment and set key in your environment)
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=...

LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=800

# =============================================================================
# Rate Limiting (slowapi)
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# =============================================================================
# Ethics & Feature Flags (first-class concerns)
# =============================================================================
REQUIRE_CONSENT_FOR_SOCIAL=true
ENABLE_SYNTHETIC_SOCIAL=true
MAX_RECOMMENDATION_CATEGORIES=8

# =============================================================================
# GraphQL Safety Limits (deliberate constraints)
# =============================================================================
GRAPHQL_MAX_QUERY_DEPTH=3
GRAPHQL_MAX_QUERY_COST=50

# =============================================================================
# MCP
# =============================================================================
MCP_ENABLED=true

# =============================================================================
# Paths
# =============================================================================
DATA_DIR=./data
